<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">

<div class="product-page-wrapper">
  <div class="container py-5">
    
    <!-- Breadcrumb -->
    <nav class="custom-breadcrumb mb-4" aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ routes.root_url }}"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item"><a href="/collections/all">Shop</a></li>
        <li class="breadcrumb-item active" aria-current="page">{{ product.title }}</li>
      </ol>
    </nav>

    <div class="row g-5">
      <!-- LEFT: Image Gallery -->
      <div class="col-lg-7">
        <div class="product-gallery">
          <div class="main-image-container mb-3 shadow-sm rounded-4 overflow-hidden">
            <img id="mainProductImage" 
                 src="{{ product.featured_image | image_url: width: 800 }}" 
                 alt="{{ product.title }}" 
                 class="img-fluid w-100 object-fit-contain">
          </div>
          
          <div class="thumbnail-slider d-flex gap-3 overflow-auto pb-2">
            {% for image in product.images %}
              <div class="thumb-wrapper">
                <img src="{{ image | image_url: width: 150 }}" 
                     class="img-thumbnail thumb-img {% if forloop.first %}active{% endif %}" 
                     onclick="changeImage(this, '{{ image | image_url: width: 800 }}')"
                     alt="{{ product.title }}">
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- RIGHT: Product Info -->
      <div class="col-lg-5">
        <div class="product-info-sticky">
          <h1 class="display-6 fw-bold mb-2">{{ product.title }}</h1>
          
          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="text-warning small">
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star-half-alt"></i>
              <span class="text-muted ms-1">(24 Reviews)</span>
            </div>
            <span class="badge bg-success-subtle text-success border border-success-subtle">In Stock</span>
          </div>

          <div class="price-wrapper mb-4">
            <h3 class="d-flex align-items-center gap-2 mb-0">
              <span class="text-primary fw-bold">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="text-muted fs-5 text-decoration-line-through">{{ product.compare_at_price | money }}</span>
                <span class="badge bg-danger rounded-pill fs-6">Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
              {% endif %}
            </h3>
          </div>

          <div class="short-description mb-4">
            <p class="text-secondary">{{ product.description | strip_html | truncatewords: 25 }}</p>
          </div>

          <form method="post" action="/cart/add" id="AddToCartForm">
            <!-- Variants Selection -->
            {% unless product.has_only_default_variant %}
              <div class="variant-selection mb-4">
                {% for option in product.options_with_values %}
                  <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">{{ option.name }}</label>
                    <div class="d-flex flex-wrap gap-2">
                      {% for value in option.values %}
                        <input type="radio" class="btn-check" name="{{ option.name }}" 
                               id="{{ option.name }}-{{ value }}" value="{{ value }}"
                               {% if option.selected_value == value %}checked{% endif %}>
                        <label class="btn btn-outline-dark btn-sm px-3 py-2 rounded-pill" for="{{ option.name }}-{{ value }}">
                          {{ value }}
                        </label>
                      {% endfor %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% endunless %}

            <!-- Hidden Master Selector -->
            <select name="id" id="product-select" class="d-none">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ variant.title }}
                </option>
              {% endfor %}
            </select>

            <!-- Quantity & CTA -->
            <div class="action-buttons mt-5">
              <div class="row g-3">
                <div class="col-md-4">
                  <div class="input-group border rounded-pill overflow-hidden">
                    <button type="button" class="btn btn-link text-dark text-decoration-none" onclick="stepQty(-1)"><i class="fas fa-minus"></i></button>
                    <input type="number" name="quantity" id="qty" value="1" min="1" class="form-control border-0 text-center fw-bold">
                    <button type="button" class="btn btn-link text-dark text-decoration-none" onclick="stepQty(1)"><i class="fas fa-plus"></i></button>
                  </div>
                </div>
                <div class="col-md-8">
                  {% if product.available %}
                    <button type="submit" class="btn btn-dark w-100 py-3 rounded-pill fw-bold text-uppercase shadow-sm">
                      <i class="fas fa-shopping-bag me-2"></i> Add to Cart
                    </button>
                  {% else %}
                    <button class="btn btn-secondary w-100 py-3 rounded-pill" disabled>Sold Out</button>
                  {% endif %}
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Tabs Section -->
    <div class="row mt-5 pt-5">
      <div class="col-12">
        <ul class="nav nav-pills justify-content-center mb-4 border-bottom pb-3" id="productTab">
          <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#desc-tab">Description</button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#shipping-tab">Shipping Info</button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#review-tab">Reviews</button></li>
        </ul>
        <div class="tab-content py-3">
          <div class="tab-pane fade show active" id="desc-tab">{{ product.description }}</div>
          <div class="tab-pane fade" id="shipping-tab">Free shipping on orders over $100. Delivered in 3-5 business days.</div>
          <div class="tab-pane fade" id="review-tab">Reviews coming soon...</div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  :root { --primary-color: #2563eb; }
  .product-page-wrapper { font-family: 'Inter', sans-serif; background-color: #fff; }
  
  /* Breadcrumb */
  .custom-breadcrumb .breadcrumb-item + .breadcrumb-item::before { content: "›"; font-size: 1.2rem; line-height: 1; }
  .custom-breadcrumb a { color: #666; text-decoration: none; font-size: 0.9rem; }
  .custom-breadcrumb .active { color: #000; font-weight: 500; }

  /* Gallery */
  .main-image-container { background: #f8f9fa; border: 1px solid #eee; height: 500px; display: flex; align-items: center; justify-content: center; }
  .main-image-container img { max-height: 100%; transition: transform 0.3s ease; }
  .main-image-container:hover img { transform: scale(1.05); }
  
  .thumb-img { width: 80px; height: 80px; object-fit: cover; cursor: pointer; border-radius: 12px; border: 2px solid transparent; opacity: 0.7; transition: 0.3s; }
  .thumb-img:hover, .thumb-img.active { opacity: 1; border-color: var(--primary-color); }

  /* Info */
  .product-info-sticky { position: sticky; top: 20px; }
  .btn-check:checked + .btn-outline-dark { background-color: #000; color: #fff; }
  
  /* Inputs */
  input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  #qty:focus { box-shadow: none; }

  /* Tabs */
  .nav-pills .nav-link { color: #666; font-weight: 500; border-radius: 30px; padding: 10px 25px; }
  .nav-pills .nav-link.active { background-color: #f3f4f6; color: #000; }
</style>


<script>
// Image change function for thumbnails
function changeImage(el, src) {
  document.getElementById("mainProductImage").src = src;
  document.querySelectorAll('.thumb-img').forEach(img => img.classList.remove('active'));
  el.classList.add('active');
}

// Quantity step function
function stepQty(amount) {
  let qtyInput = document.getElementById("qty");
  let newVal = parseInt(qtyInput.value) + amount;
  if (newVal >= 1) qtyInput.value = newVal;
}

// ================= VARIANT UPDATE LOGIC =================
// Protiti variant er data ekta JSON object e rakha hocche
const productVariants = {{ product.variants | json }};

document.querySelectorAll('input[type="radio"]').forEach(radio => {
  radio.addEventListener('change', function() {
    // Shobgulo selected option ke eksathe kore variant title banano (e.g., "Red / XL")
    let selectedOptions = [];
    document.querySelectorAll('input[type="radio"]:checked').forEach(checked => {
      selectedOptions.push(checked.value);
    });
    
    let selectedVariantTitle = selectedOptions.join(' / ');
    
    // JSON theke matching variant khuje ber kora
    let foundVariant = productVariants.find(variant => variant.title === selectedVariantTitle);

    if (foundVariant) {
      // 1. Update Hidden Input (Form er jonno)
      document.getElementById('product-select').value = foundVariant.id;

      // 2. Update Price (Money format kora hoyeche)
      const formattedPrice = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(foundVariant.price / 100);
      document.querySelector('.text-primary.fw-bold').innerText = formattedPrice;

      // 3. Update Image (Jodi variant er specific image thake)
      if (foundVariant.featured_image) {
        document.getElementById("mainProductImage").src = foundVariant.featured_image.src;
      }

      // 4. Update Button Status (Stock check)
      const cartBtn = document.querySelector('button[type="submit"]');
      if (foundVariant.available) {
        cartBtn.disabled = false;
        cartBtn.innerText = "Add to Cart";
        cartBtn.classList.replace('btn-secondary', 'btn-dark');
      } else {
        cartBtn.disabled = true;
        cartBtn.innerText = "Sold Out";
        cartBtn.classList.replace('btn-dark', 'btn-secondary');
      }
    }
  });
});
</script>

{% schema %}
{
  "name": "Main Product Page",
  "tag": "section",
  "settings": []
}
{% endschema %}