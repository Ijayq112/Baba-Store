{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-magazine-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
    padding-bottom: {{ block.settings.header_spacing | divided_by: 2 }}px;
    border-bottom: {{ block.settings.divider_width }}px solid {{ block.settings.divider_color }};
  }

  .ai-magazine-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px;
    font-weight: 700;
    letter-spacing: -0.5px;
    line-height: 1.2;
  }

  .ai-magazine-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.5;
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-magazine-hero-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
  }

  .ai-magazine-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 500px;
    overflow: hidden;
    position: relative;
  }

  .ai-magazine-hero-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-magazine-hero-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-magazine-hero-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.accent_color }};
    margin-bottom: 12px;
  }

  .ai-magazine-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    color: {{ block.settings.article_title_color }};
    margin: 0 0 15px;
    font-weight: 700;
    line-height: 1.3;
  }

  .ai-magazine-hero-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.excerpt_color }};
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .ai-magazine-hero-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 14px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-magazine-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 180px;
    overflow: hidden;
    position: relative;
  }

  .ai-magazine-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 120px;
    max-height: 120px;
  }

  .ai-magazine-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding | times: 0.8 }}px;
    flex-grow: 1;
  }

  .ai-magazine-card-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.accent_color }};
    margin-bottom: 8px;
  }

  .ai-magazine-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.article_title_color }};
    margin: 0 0 10px;
    font-weight: 600;
    line-height: 1.4;
  }

  .ai-magazine-card-meta-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-bottom-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-small-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
  }

  .ai-magazine-small-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    overflow: hidden;
    position: relative;
  }

  .ai-magazine-small-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-small-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-small-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 100px;
    max-height: 100px;
  }

  .ai-magazine-small-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding | times: 0.7 }}px;
  }

  .ai-magazine-small-card-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.accent_color }};
    margin-bottom: 6px;
  }

  .ai-magazine-small-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.small_card_title_size }}px;
    color: {{ block.settings.article_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.4;
  }

  .ai-magazine-small-card-meta-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-magazine-link-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  @media screen and (max-width: 990px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-magazine-hero-{{ ai_gen_id }},
    .ai-magazine-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-magazine-bottom-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-magazine-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.7 }}px;
    }

    .ai-magazine-hero-image-{{ ai_gen_id }} {
      height: 300px;
    }

    .ai-magazine-card-image-{{ ai_gen_id }} {
      height: 200px;
    }
  }
{% endstyle %}

<magazine-editorial-{{ ai_gen_id }}
  class="ai-magazine-layout-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-magazine-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-magazine-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-magazine-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <div class="ai-magazine-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-magazine-grid-{{ ai_gen_id }}">
      <div class="ai-magazine-hero-{{ ai_gen_id }}">
        {% if block.settings.hero_article != blank %}
          <a href="{{ block.settings.hero_article.url }}" class="ai-magazine-link-{{ ai_gen_id }}">
            <div class="ai-magazine-hero-image-{{ ai_gen_id }}">
              {% if block.settings.hero_article.image %}
                <img
                  src="{{ block.settings.hero_article.image | image_url: width: 1000 }}"
                  alt="{{ block.settings.hero_article.image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.hero_article.image.width }}"
                  height="{{ block.settings.hero_article.image.height }}"
                >
              {% else %}
                <div class="ai-magazine-hero-image-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-magazine-hero-content-{{ ai_gen_id }}">
              {% if block.settings.hero_article.tags.size > 0 %}
                <span class="ai-magazine-hero-category-{{ ai_gen_id }}">{{ block.settings.hero_article.tags.first }}</span>
              {% endif %}
              <h3 class="ai-magazine-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_article.title }}</h3>
              {% if block.settings.hero_article.excerpt != blank %}
                <div class="ai-magazine-hero-excerpt-{{ ai_gen_id }}">{{ block.settings.hero_article.excerpt | strip_html | truncate: 180 }}</div>
              {% endif %}
              <div class="ai-magazine-hero-meta-{{ ai_gen_id }}">
                {% if block.settings.hero_article.author != blank %}
                  <span>{{ block.settings.hero_article.author }}</span>
                {% endif %}
                <span>{{ block.settings.hero_article.published_at | date: '%B %d, %Y' }}</span>
              </div>
            </div>
          </a>
        {% else %}
          <div class="ai-magazine-hero-image-{{ ai_gen_id }}">
            <div class="ai-magazine-hero-image-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          </div>
          <div class="ai-magazine-hero-content-{{ ai_gen_id }}">
            <span class="ai-magazine-hero-category-{{ ai_gen_id }}">Featured</span>
            <h3 class="ai-magazine-hero-title-{{ ai_gen_id }}">Your Featured Article Title</h3>
            <div class="ai-magazine-hero-excerpt-{{ ai_gen_id }}">Add your hero article to showcase your most important content in this prominent editorial space.</div>
            <div class="ai-magazine-hero-meta-{{ ai_gen_id }}">
              <span>Author Name</span>
              <span>{{ 'now' | date: '%B %d, %Y' }}</span>
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-magazine-sidebar-{{ ai_gen_id }}">
        {% for i in (1..2) %}
          {% liquid
            assign article_key = 'sidebar_article_' | append: i
            assign article = block.settings[article_key]
          %}
          <div class="ai-magazine-card-{{ ai_gen_id }}">
            {% if article != blank %}
              <a href="{{ article.url }}" class="ai-magazine-link-{{ ai_gen_id }}">
                <div class="ai-magazine-card-image-{{ ai_gen_id }}">
                  {% if article.image %}
                    <img
                      src="{{ article.image | image_url: width: 500 }}"
                      alt="{{ article.image.alt | escape }}"
                      loading="lazy"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                    >
                  {% else %}
                    <div class="ai-magazine-card-image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-magazine-card-content-{{ ai_gen_id }}">
                  {% if article.tags.size > 0 %}
                    <span class="ai-magazine-card-category-{{ ai_gen_id }}">{{ article.tags.first }}</span>
                  {% endif %}
                  <h4 class="ai-magazine-card-title-{{ ai_gen_id }}">{{ article.title }}</h4>
                  <div class="ai-magazine-card-meta-{{ ai_gen_id }}">{{ article.published_at | date: '%B %d, %Y' }}</div>
                </div>
              </a>
            {% else %}
              <div class="ai-magazine-card-image-{{ ai_gen_id }}">
                <div class="ai-magazine-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-magazine-card-content-{{ ai_gen_id }}">
                <span class="ai-magazine-card-category-{{ ai_gen_id }}">Category</span>
                <h4 class="ai-magazine-card-title-{{ ai_gen_id }}">Article Title {{ i }}</h4>
                <div class="ai-magazine-card-meta-{{ ai_gen_id }}">{{ 'now' | date: '%B %d, %Y' }}</div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-magazine-bottom-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign article_key = 'bottom_article_' | append: i
          assign article = block.settings[article_key]
        %}
        <div class="ai-magazine-small-card-{{ ai_gen_id }}">
          {% if article != blank %}
            <a href="{{ article.url }}" class="ai-magazine-link-{{ ai_gen_id }}">
              <div class="ai-magazine-small-card-image-{{ ai_gen_id }}">
                {% if article.image %}
                  <img
                    src="{{ article.image | image_url: width: 500 }}"
                    alt="{{ article.image.alt | escape }}"
                    loading="lazy"
                    width="{{ article.image.width }}"
                    height="{{ article.image.height }}"
                  >
                {% else %}
                  <div class="ai-magazine-small-card-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-magazine-small-card-content-{{ ai_gen_id }}">
                {% if article.tags.size > 0 %}
                  <span class="ai-magazine-small-card-category-{{ ai_gen_id }}">{{ article.tags.first }}</span>
                {% endif %}
                <h5 class="ai-magazine-small-card-title-{{ ai_gen_id }}">{{ article.title }}</h5>
                <div class="ai-magazine-small-card-meta-{{ ai_gen_id }}">{{ article.published_at | date: '%b %d' }}</div>
              </div>
            </a>
          {% else %}
            <div class="ai-magazine-small-card-image-{{ ai_gen_id }}">
              <div class="ai-magazine-small-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-magazine-small-card-content-{{ ai_gen_id }}">
              <span class="ai-magazine-small-card-category-{{ ai_gen_id }}">Category</span>
              <h5 class="ai-magazine-small-card-title-{{ ai_gen_id }}">Article Title {{ i }}</h5>
              <div class="ai-magazine-small-card-meta-{{ ai_gen_id }}">{{ 'now' | date: '%b %d' }}</div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineEditorial{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('magazine-editorial-{{ ai_gen_id }}', MagazineEditorial{{ai_gen_id}});
  })();
</script>

{% schema %}
{
  "name": "Magazine editorial layout",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Latest Stories"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Subtitle",
      "default": "Curated articles and editorial content"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Hero article"
    },
    {
      "type": "article",
      "id": "hero_article",
      "label": "Featured article"
    },
    {
      "type": "header",
      "content": "Sidebar articles"
    },
    {
      "type": "article",
      "id": "sidebar_article_1",
      "label": "Sidebar article 1"
    },
    {
      "type": "article",
      "id": "sidebar_article_2",
      "label": "Sidebar article 2"
    },
    {
      "type": "header",
      "content": "Bottom articles"
    },
    {
      "type": "article",
      "id": "bottom_article_1",
      "label": "Bottom article 1"
    },
    {
      "type": "article",
      "id": "bottom_article_2",
      "label": "Bottom article 2"
    },
    {
      "type": "article",
      "id": "bottom_article_3",
      "label": "Bottom article 3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Content spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Section title size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
