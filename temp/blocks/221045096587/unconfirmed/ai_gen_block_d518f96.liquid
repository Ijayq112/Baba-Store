      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "excerpt_size",
      "label": "Excerpt size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Section title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
